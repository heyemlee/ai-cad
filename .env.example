# Copy this file to .env.local and adjust as needed.
# Note: the current codebase does NOT yet read these — paths are hardcoded
# in lib/autocad.ts. These are placeholders for future configurability.

# AutoCAD 2026 application bundle (macOS)
# AUTOCAD_APP=/Applications/Autodesk/AutoCAD 2026/AutoCAD 2026.app

# AcCoreConsole binary used for headless drawing generation
# ACCORE_CONSOLE=/Applications/Autodesk/AutoCAD 2026/AutoCAD 2026.app/Contents/Helpers/AcCoreConsole.app/Contents/MacOS/AcCoreConsole

# Default DWG template
# AUTOCAD_TEMPLATE=/Users/<you>/Library/Application Support/Autodesk/AutoCAD 2026/R25.1/local/@en@/Template/acad.dwt

# Directory where generated drawings are written (defaults to ./output)
# OUTPUT_DIR=./output
